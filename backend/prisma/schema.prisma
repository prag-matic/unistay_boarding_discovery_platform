// Prisma schema for UniStay Boarding Discovery Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  OWNER
  ADMIN
}

enum BoardingType {
  SINGLE_ROOM
  SHARED_ROOM
  ANNEX
  HOUSE
}

enum GenderPref {
  MALE
  FEMALE
  ANY
}

enum BoardingStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  INACTIVE
}

enum ReservationStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  REJECTED
  EXPIRED
}

enum RentalPeriodStatus {
  UPCOMING
  DUE
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  ONLINE
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum VisitRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum ReactionType {
  LIKE
  DISLIKE
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  passwordHash     String
  firstName        String
  lastName         String
  role             Role     @default(STUDENT)
  phone            String?
  university       String?
  nicNumber        String?
  profileImageUrl  String?
  isVerified       Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  refreshTokens           RefreshToken[]
  boardings               Boarding[]
  savedBoardings          SavedBoarding[]
  reservations            Reservation[]  @relation("StudentReservations")
  reviews                 Review[]       @relation("StudentReviews")
  reviewComments          ReviewComment[]
  reviewReactions         ReviewReaction[]
  reviewCommentReactions  ReviewCommentReaction[]
  payments                Payment[]      @relation("StudentPayments")
  visitRequests           VisitRequest[] @relation("StudentVisitRequests")

  @@map("users")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model RefreshToken {
  id               String    @id @default(cuid())
  tokenHash        String    @unique
  userId           String
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?
  replacedByTokenId String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Boarding {
  id               String         @id @default(cuid())
  ownerId          String
  title            String
  slug             String         @unique
  description      String
  city             String
  district         String
  address          String?
  monthlyRent      Int
  boardingType     BoardingType
  genderPref       GenderPref
  isFurnished      Boolean        @default(false)
  hasWifi          Boolean        @default(false)
  nearUniversity   String?
  latitude         Float
  longitude        Float
  maxOccupants     Int
  currentOccupants Int            @default(0)
  status           BoardingStatus @default(DRAFT)
  rejectionReason  String?
  isDeleted        Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  owner   User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images  BoardingImage[]
  rules   BoardingRule[]
  savedBy SavedBoarding[]
  reservations  Reservation[]
  reviews       Review[]
  visitRequests VisitRequest[]

  @@map("boardings")
}

model BoardingImage {
  id         String   @id @default(cuid())
  boardingId String
  url        String
  publicId   String
  createdAt  DateTime @default(now())

  boarding Boarding @relation(fields: [boardingId], references: [id], onDelete: Cascade)

  @@map("boarding_images")
}

model BoardingRule {
  id         String @id @default(cuid())
  boardingId String
  rule       String

  boarding Boarding @relation(fields: [boardingId], references: [id], onDelete: Cascade)

  @@map("boarding_rules")
}

model SavedBoarding {
  id         String   @id @default(cuid())
  boardingId String
  studentId  String
  createdAt  DateTime @default(now())

  boarding Boarding @relation(fields: [boardingId], references: [id], onDelete: Cascade)
  student  User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([boardingId, studentId])
  @@map("saved_boardings")
}


model Reservation {
  id               String            @id @default(cuid())
  studentId        String
  boardingId       String
  status           ReservationStatus @default(PENDING)
  moveInDate       DateTime          @db.Date
  specialRequests  String?
  rentSnapshot     Int
  boardingSnapshot Json
  rejectionReason  String?
  expiresAt        DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student       User          @relation("StudentReservations", fields: [studentId], references: [id], onDelete: Cascade)
  boarding      Boarding      @relation(fields: [boardingId], references: [id], onDelete: Cascade)
  rentalPeriods RentalPeriod[]
  payments      Payment[] @relation("ReservationPayments")

  @@map("reservations")
}

model RentalPeriod {
  id            String             @id @default(cuid())
  reservationId String
  periodLabel   String
  dueDate       DateTime           @db.Date
  amountDue     Int
  status        RentalPeriodStatus @default(UPCOMING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  payments    Payment[]   @relation("RentalPeriodPayments")

  @@map("rental_periods")
}

model Payment {
  id              String        @id @default(cuid())
  rentalPeriodId  String
  reservationId   String
  studentId       String
  amount          Decimal       @db.Decimal(12, 2)
  paymentMethod   PaymentMethod
  referenceNumber String?
  proofImageUrl   String?
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime
  rejectionReason String?
  confirmedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student      User          @relation("StudentPayments", fields: [studentId], references: [id], onDelete: Cascade)
  reservation  Reservation   @relation("ReservationPayments", fields: [reservationId], references: [id], onDelete: Cascade)
  rentalPeriod RentalPeriod  @relation("RentalPeriodPayments", fields: [rentalPeriodId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model VisitRequest {
  id               String             @id @default(cuid())
  studentId        String
  boardingId       String
  status           VisitRequestStatus @default(PENDING)
  requestedStartAt DateTime
  requestedEndAt   DateTime
  message          String?
  rejectionReason  String?
  expiresAt        DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student  User     @relation("StudentVisitRequests", fields: [studentId], references: [id], onDelete: Cascade)
  boarding Boarding @relation(fields: [boardingId], references: [id], onDelete: Cascade)

  @@map("visit_requests")
}

// Review model - students rate boardings after their stay
model Review {
  id            String    @id @default(cuid())
  boardingId    String
  boarding      Boarding  @relation(fields: [boardingId], references: [id], onDelete: Cascade)
  studentId     String
  student       User      @relation("StudentReviews", fields: [studentId], references: [id], onDelete: Cascade)
  rating        Int       // 1-5 stars
  comment       String?
  commentedAt   DateTime  @default(now())
  editedAt      DateTime? // Null = can edit, Not null = already edited (one-time edit)
  likeCount     Int       @default(0)
  dislikeCount  Int       @default(0)
  images        String[]  @default([]) // Array of image paths (max 5)
  video         String?   // Single video path (optional)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  comments ReviewComment[]
  reactions ReviewReaction[]

  @@index([boardingId])
  @@index([studentId])
  @@index([rating])

  // Constraints
  @@map("reviews")
}

// ReviewComment model - owners/others can reply to reviews
model ReviewComment {
  id            String    @id @default(cuid())
  reviewId      String
  review        Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  commentorId   String
  commentor     User      @relation(fields: [commentorId], references: [id], onDelete: Cascade)
  comment       String
  commentedAt   DateTime  @default(now())
  editedAt      DateTime? // Null = can edit, Not null = already edited (one-time edit)
  likeCount     Int       @default(0)
  dislikeCount  Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  reactions ReviewCommentReaction[]

  @@index([reviewId])
  @@index([commentorId])

  // Constraints
  @@map("review_comments")
}

// ReviewReaction model - track likes/dislikes on reviews
model ReviewReaction {
  id        String       @id @default(cuid())
  reviewId  String
  review    Review       @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      ReactionType
  createdAt DateTime     @default(now())

  @@unique([reviewId, userId]) // One reaction per user per review
  @@index([reviewId])
  @@index([userId])

  @@map("review_reactions")
}

// ReviewCommentReaction model - track likes/dislikes on review comments
model ReviewCommentReaction {
  id              String          @id @default(cuid())
  reviewCommentId String
  reviewComment   ReviewComment   @relation(fields: [reviewCommentId], references: [id], onDelete: Cascade)
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            ReactionType
  createdAt       DateTime        @default(now())

  @@unique([reviewCommentId, userId]) // One reaction per user per comment
  @@index([reviewCommentId])
  @@index([userId])

  @@map("review_comment_reactions")
}
