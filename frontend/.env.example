# API Configuration
# Backend API URL (optional - defaults to http://localhost:3000/api)
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# For production/staging environments, uncomment and update:
# EXPO_PUBLIC_API_URL=https://api.unistay.com

# Google Maps API key
# Enable "Maps SDK for Android" and "Maps SDK for iOS" in the Google Cloud Console.
# https://console.cloud.google.com/google/maps-apis/
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
